                    <button type="submit" class="btn btn-outline-success btn-sm">Search</button>
                </form>
                <button data-bs-toggle="modal" data-bs-target="#CreateNewRelation" type="button" class="btn btn-secondary btn-sm"><i class="fas fa-user-plus"></i></button>
