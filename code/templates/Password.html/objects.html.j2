{% import 'objects.html.j2' as objs %}




{% macro SearchPasswordIterm() %}
<div class="input-group">
  <form class="d-flex gap-2" method="get" onsubmit="return SubmitSearchPassword();">
      <input id="searchpassword_inputtxt" class="form-control form-control-sm" type="text" placeholder="Search" aria-label="Search">
      <button onclick="SubmitSearchPassword()" class="btn btn-outline-success btn-sm">Search</button>
  </form>
</div>

<script>
  function SubmitSearchPassword() {
    var txt = document.getElementById("searchpassword_inputtxt").value
    var Url = "{{url_for('Password_Search',txt='txt')}}"
    Url = Url.replace('txt',txt)

    $.ajax({
      url: Url,
      error: function(xhr, statusText, err) {
        swal("error"+xhr.status);
      },
      success: function(data) {
        document.getElementById("searchpasswordlist").innerHTML = data
        ShowBootstrapModal('searchpasswordmodal')
      },
      type: 'GET'
    });

    return false
}

</script>
{% call objs.BootstrapModalBody(uid='searchpasswordmodal',head='results') %}
 <div class='list-group' id='searchpasswordlist'>
 </div>
{% endcall %}


{%- endmacro %}
















{% macro AddPasswordClass(classform) %}
<div class="btn-group me-2" role="group" aria-label="Password class actions">
  <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#password_add_class">
    New class
  </button>
</div>




<div class="modal fade" id="password_add_class" tabindex="-1" aria-labelledby="password_add_classLabel" aria-hidden="true">
  <div class="modal-dialog">
    <form method='post' action = "{{url_for('PasswordAddClass')}}">
      {{ classform.hidden_tag() }}
      <div class="modal-content">
        <div class="modal-body">
          <div class="mb-3">
            <label for="recipient-name" class="col-form-label">New class name:</label>
            <!-- <input type="text" class="form-control" id="recipient-name"> -->
            {{ classform.Class(class="form-control") }}
          </div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">add</button>
        </div>
      </div>
    </form>
  </div>
</div>
{%- endmacro %}





{% macro AddPasswordIterm(Class,itemform) %}
<div class="btn-group me-2" role="group" aria-label="Password item actions">
  <button type="button" class="btn btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#password_add_class_item">
    New iterm
  </button>
</div>


<div class="modal fade" id="password_add_class_item" tabindex="-1" aria-labelledby="password_add_class_itemLabel" aria-hidden="true">
  <div class="modal-dialog">
    <form method='post' action="{{url_for('PasswordAddItem',Class=Class)}}" >
      {{itemform.hidden_tag()}}
      <div class="modal-content">
        <div class="modal-body">
          <div class="mb-3">
            <label for="recipient-name" class="col-form-label">New item name:</label>
            <!-- <input type="text" class="form-control" id="recipient-name"> -->
            {{itemform.item(class="form-control")}}
          </div>
          <div class="d-none"> {{itemform.time(id="password_add_class_item_gettime")}} </div>
        </div>
        <div class="modal-footer">
          <button onclick="return submitpassword_add_class_item()" type="submit" class="btn btn-primary">add</button>
        </div>
      </div>
    </form>
  </div>
</div>

<script>
function submitpassword_add_class_item() {
  var nowsec = getsecnow();
  // alert(nowsec)
  document.getElementById('password_add_class_item_gettime').value = nowsec;
  return true;
}
</script>


{%- endmacro %}




